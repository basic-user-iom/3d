# Copy to .env and fill in values as needed.
# Never commit .env — it is listed in .gitignore.

# Cesium Ion access token for 3D Tiles demos (optional)
# https://cesium.com/ion/tokens
VITE_CESIUM_ION_ACCESS_TOKEN=

# Replicate API token for AI image enhancement (optional)
# https://replicate.com/account/api-tokens
VITE_REPLICATE_API_TOKEN=

# Custom path for web-ifc WASM files (optional; defaults to /web-ifc/)
# VITE_IFC_WASM_PATH=/web-ifc/
